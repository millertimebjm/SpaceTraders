@using SpaceTraders.Models
@using System.Text.Json
@using System.Dynamic
@using SpaceTraders.Mvc.Services
@model ShipLogsViewModel
@{
    ViewData["Title"] = "Ship Logs";
}

<h3><u>Ship Logs</u></h6>

<span>
    <select class="select" onchange="reload(this.value)">
        @foreach (var shipStatus in ShipSortHelper.ShipStatusSort(await Model.ShipStatusesTask))
        {
            var selected = shipStatus.Ship.Symbol == Model.FilterModel.ShipSymbol;
            <option value="@shipStatus.Ship.Symbol" selected="@selected">@shipStatus.Ship.Symbol (@shipStatus.Ship.Registration.Role)</option>
        }
    </select>
</span>

<table class="table" style="font-size: 0.8em;">
    <thead>
        <tr>
            <th style="width: 100px;">ShipSymbol</th>
            <th>Type</th>
            <th>Start</th>
            <th>End</th>
            <th>Data</th>
            <th>@((await Model.ShipLogsTask).Count())</th>
        </tr>
    </thead>
    <tbody>
        @foreach (ShipLog shipLog in await Model.ShipLogsTask)
        {
            <tr>
                <td>@shipLog.ShipSymbol</td>
                <td>@shipLog.ShipLogEnum</td>
                <td>@shipLog.StartedDateTimeUtc</td>
                <td>@shipLog.CompletedDateTimeUtc</td>
                <td>
                    @{
                        var data = JsonSerializer.Deserialize<ExpandoObject>(shipLog.JsonData);
                    }
                    <ul>
                        @foreach (var datum in (IDictionary<string, object>)data)
                        {
                            <li>
                                <strong>@datum.Key</strong>: @datum.Value
                            </li>
                        }
                    </ul>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function reload(value) {
        window.location.href = "/shiplogs/?shipsymbol=" + value;
    }
</script>