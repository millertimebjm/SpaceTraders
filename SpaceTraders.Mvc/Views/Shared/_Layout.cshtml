@using SpaceTraders.Models
@using SpaceTraders.Services.Systems
@using SpaceTraders.Services.Waypoints
@{
    var agent = (Agent)ViewBag.Agent;
    var shipStatuses = (IEnumerable<ShipStatus>)ViewBag.ShipStatuses;
    var systems = (IReadOnlyList<STSystem>)ViewBag.Systems;
    var reachableSystems = SystemsService.Traverse(systems, WaypointsService.ExtractSystemFromWaypoint(agent.Headquarters));
    Dictionary<string, string> systemStrings = new ();
    foreach (var system in systems.OrderByDescending(s => shipStatuses.Count(ss => ss.Ship.Nav.SystemSymbol == s.Symbol)))
    {
        var shipCount = shipStatuses.Count(ss => ss.Ship.Nav.SystemSymbol == system.Symbol);
        var shipCountString = 
            shipCount > 0 
            ? $"({shipCount} ships)" 
            : !systems.Any(s => s.Symbol == system.Symbol) 
            ? " unreachable"
            : "";
        systemStrings.Add(system.Symbol, $"{system.Symbol} {shipCountString}");
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SpaceTraders.Mvc</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SpaceTraders.Mvc.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/scrollToTop.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">SpaceTraders.Mvc</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item"></li>
                            <a class="nav-link text-dark" asp-area="" asp-controller="Ships" asp-action="Index">Ships</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Systems
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                @foreach (var systemString in systemStrings)
                                {
                                    <li><a class="dropdown-item" href="/systems/@systemString.Key">@systemString.Value</a></li>
                                }
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Maps
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item" href="/map/galaxy">Galaxy</a></li>
                                @foreach (var systemString in systemStrings)
                                {
                                    <li><a class="dropdown-item" href="/map/?systemsymbol=@systemString.Key">@systemString.Value</a></li>
                                }
                            </ul>
                        </li>
                        <li class="nav-item"></li>
                            <a class="nav-link text-dark" href="/shiplogs">Logs</a>
                        </li>
                        <li class="nav-item"></li>
                            <a class="nav-link text-dark" href="/marketplaces/trademodels">Trade Models</a>
                        </li>
                        <li class="nav-item">
                            @if (ViewBag.CurrentShipSymbol is null)
                            {
                                <a class="nav-link text-dark" href="/ships"><b>No Ship</b></a>
                            }
                            else 
                            {
                                <text><a class="nav-link text-dark" href="/ships/@(ViewBag.CurrentShipSymbol)"><b>@(ViewBag.CurrentShipSymbol)</b></a></text>
                            }
                        </li>
                        @if (ViewBag.CurrentWaypointSymbol is not null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/waypoints/@ViewBag.CurrentWaypointSymbol">at <b>@ViewBag.CurrentWaypointSymbol</b></a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/ships/deactivate">Deactivate</a>
                            </li>
                        }
                        <li class="nav-item"></li>
                            <a class="nav-link text-dark" href="/agents/refresh">@ViewBag.CurrentCredits</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

     <button onclick="topFunction()" id="scrollToTopButton" title="Go to top">Top</button> 

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - SpaceTraders.Mvc - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/scrollToTop.js"></script>
    <script src="~/js/countdown.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

