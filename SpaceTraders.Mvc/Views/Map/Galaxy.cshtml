                foreach (var shipStatus in shipStatusesInSystem)
                {
                    var fromX = shipStatus.Ship.Nav.Route.Origin.X;
                    var fromY = shipStatus.Ship.Nav.Route.Origin.Y;
                    var toX = shipStatus.Ship.Nav.Route.Destination.X;
                    var toY = shipStatus.Ship.Nav.Route.Destination.Y;
