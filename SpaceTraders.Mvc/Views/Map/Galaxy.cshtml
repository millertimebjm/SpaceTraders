                    var endDateTime = shipStatus.Ship.Nav.Route.Arrival;
                    DateTime now = DateTime.UtcNow;
                    double totalDurationTicks = (endDateTime - startDateTime).Ticks;
                    double elapsedTicks = (now - startDateTime).Ticks;

                    // 2. Calculate progress (clamped between 0 and 1)
                    double progress = elapsedTicks / totalDurationTicks;
                    progress = Math.Max(0, Math.Min(1, progress)); 

                    // 3. Interpolate X and Y coordinates
                    double currentX = fromX + (toX - fromX) * progress;
                    double currentY = fromY + (toY - fromY) * progress;
                    
                    drones.Add(new MapDronesViewModel((int)currentX + (GRID_SIZE / 2), (int)currentY + (GRID_SIZE / 2), shipStatus.Ship.Symbol.Substring(shipStatus.Ship.Symbol.LastIndexOf("-")+1, shipStatus.Ship.Symbol.Length - (shipStatus.Ship.Symbol.LastIndexOf("-")+1)), 4));
