@using System.Text.Json
@using System.Text.Encodings.Web
@using SpaceTraders.Models
@using SpaceTraders.Services.Systems
@using SpaceTraders.Services.Waypoints
@model GalaxyViewModel;

@{
    Layout = null;
    var systems = await Model.SystemsTask;
    Agent agent = (Agent)ViewBag.Agent;
}
<html>
    <head>
        <title>Map - Galaxy</title>
        <style>
            body {
                margin: 0;
                padding: 0;
                overflow: hidden;
                background-color: #0b0e14;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            #ui-layer {
                position: absolute;
                top: 20px;
                left: 20px;
                color: #00ffcc;
                background: rgba(0, 0, 0, 0.7);
                padding: 15px;
                border-radius: 8px;
                border: 1px solid #00ffcc;
                pointer-events: none;
                text-shadow: 0 0 5px #00ffcc;
            }

            canvas {
                display: block;
                cursor: grab;
            }

            canvas:active {
                cursor: grabbing;
            }
        </style>
    </head>
    <body>
        <div id="ui-layer">
            <strong>Grid Navigator</strong><br>
            • Scroll to Zoom<br>
            • Click & Drag to Pan<br>
            <span id="stats">Zoom: 1.00x</span><br/>
            <span id="coords">0, 0</span><br/>
            <button>reset</button>
        </div>

        <canvas id="gridCanvas" style="position: relative; z-index: 10;"></canvas>

        <script>
            @{
                const int GRID_SIZE = 2000;
                var headquartersSystemSymbol = WaypointsService.ExtractSystemFromWaypoint(agent.Headquarters);
                var headquartersSystem = systems.Single(s => s.Symbol == headquartersSystemSymbol);
                var xOffset = (GRID_SIZE/2) - headquartersSystem.X;
                var yOffset = (GRID_SIZE/2) - headquartersSystem.Y;
                
                List<MapStaticObjectsViewModel> staticObjects = new ();
                foreach (var system in systems)
                {
                    var color = "#ffffff";
                    
                    staticObjects.Add(
                        new MapStaticObjectsViewModel(
                            system.X + xOffset, 
                            system.Y + yOffset, 
                            system.Symbol, 
                            system.Symbol == headquartersSystemSymbol ? "#ff0077" : color),
                            true);
                }
            }
            const staticObjects = @(Html.Raw(JsonSerializer.Serialize(staticObjects, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase, Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping })))

            @{
                var galaxyLineViewModels = new List<GalaxyLineViewModel>();
                var links = SystemsService.TraverseLinks(systems, headquartersSystemSymbol);
                foreach (var link in links)
                {
                    galaxyLineViewModels.Add(new (link.Item1.X + xOffset, link.Item1.Y + yOffset, link.Item2.X + xOffset, link.Item2.Y + yOffset, "#ffffff", 1, link.Item3 ? [] : [5,5]));
                }
            }
            const systemLines = @(Html.Raw(JsonSerializer.Serialize(galaxyLineViewModels, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase, Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping })))


@* const lineModel = [
    { startX: 50,  startY: 50,  endX: 300, endY: 50,  color: 'white', width: 1, dash: [] },      // Solid
    { startX: 50,  startY: 80,  endX: 300, endY: 80,  color: 'white', width: 1, dash: [2, 2] },  // Dotted
    { startX: 50,  startY: 110, endX: 300, endY: 110, color: 'white', width: 2, dash: [10, 5] }  // Dashed
]; *@



            @* @{
